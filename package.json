{
  "name": "mikroliving",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build:client": "node --experimental-strip-types node_modules/vite/bin/vite.js build --configLoader native",
    "build:server": "node node_modules/esbuild/bin/esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=build/server.js",
    "build": "npm run build:client && npm run build:server",
    "start": "node build/server.js",
    "preview": "vite preview",
    "clean": "powershell -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }; if (Test-Path build) { Remove-Item build -Recurse -Force }\"",
    "lint": "tsc --noEmit",
    "test": "node scripts/run-component-tests.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.6.0",
    "motion": "^12.23.24",
    "mysql2": "^3.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
  }
}
