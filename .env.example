PORT="3000"
JWT_SECRET="replace-with-a-long-random-secret"

# Optional: only needed if you use Gemini features in the frontend build.
GEMINI_API_KEY=""

# Optional: set these to split info logs and warn/error logs into separate files.
LOG_INFO_FILE="./logs/app-info.log"
LOG_ERROR_FILE="./logs/app-error.log"
LOG_MAX_SIZE_MB="10"
LOG_MAX_FILES="5"
LOG_SERVICE_NAME="mikro-living"

# Database
DB_HOST="127.0.0.1"
DB_USER="root"
DB_PASSWORD=""
DB_NAME="mikroliving"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Rate limits
RATE_LIMIT_ADMIN_LOGIN_WINDOW_MS="900000"
RATE_LIMIT_ADMIN_LOGIN_MAX="5"
RATE_LIMIT_ADMIN_WRITE_WINDOW_MS="300000"
RATE_LIMIT_ADMIN_WRITE_MAX="30"
RATE_LIMIT_ADMIN_UPLOAD_WINDOW_MS="600000"
RATE_LIMIT_ADMIN_UPLOAD_MAX="10"
RATE_LIMIT_CONTACT_WINDOW_MS="600000"
RATE_LIMIT_CONTACT_MAX="5"
